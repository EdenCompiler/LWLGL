(defun %ensure-glfw () (ensure-native-module :glfw))

(defun get-version ()
  "Returns GLFW's runtime MAJOR, MINOR and REVISION as three values.
This is safe before GLFW initialization."
  (%ensure-glfw)
  (cffi:with-foreign-objects ((major :int) (minor :int) (revision :int))
    (%glfw-get-version major minor revision)
    (values (cffi:mem-ref major :int)
            (cffi:mem-ref minor :int)
            (cffi:mem-ref revision :int))))

(defun %version-at-least-p (wanted-major wanted-minor wanted-revision)
  (multiple-value-bind (major minor revision) (get-version)
    (or (> major wanted-major)
        (and (= major wanted-major)
             (or (> minor wanted-minor)
                 (and (= minor wanted-minor)
                      (>= revision wanted-revision)))))))

(defun init-hint (hint value)
  "Sets a GLFW initialization hint. Must be called before INIT."
  (%ensure-glfw)
  (%glfw-init-hint hint value)
  value)

(defun %string-choice (value)
  (and value (string-downcase (string-trim '(#\Space #\Tab #\Newline #\Return) value))))

(defun %platform-choice ()
  (let ((env (%string-choice (uiop:getenv "LWLGL_GLFW_PLATFORM"))))
    (cond ((member env '("x11") :test #'string=) :x11)
          ((member env '("wayland" "wl") :test #'string=) :wayland)
          ((member env '("null" "headless") :test #'string=) :null)
          ((member env '("auto" "") :test #'string=) :auto)
          (env (warn "Ignoring unknown LWLGL_GLFW_PLATFORM value ~S." env) :auto)
          (t *glfw-platform-preference*))))

(defun %wayland-session-p (platform-choice)
  (or (eq platform-choice :wayland)
      (and (eq platform-choice :auto)
           (string-equal (or (uiop:getenv "XDG_SESSION_TYPE") "") "wayland")
           (not (null (uiop:getenv "WAYLAND_DISPLAY"))))))

(defun %configure-init-hints ()
  "Applies LWLGL's safe GLFW initialization policy before glfwInit.
On GLFW 3.4+, LWLGL_GLFW_PLATFORM may force x11/wayland/null.
On Wayland with GLFW >= 3.3.9, libdecor is disabled by default because its
GTK plugin can be unsafe in embedded/non-C runtimes; set
LWLGL_GLFW_LIBDECOR=prefer to restore GLFW's libdecor preference."
  (let ((choice (%platform-choice)))
    ;; Runtime platform selection was added in GLFW 3.4.
    (when (%version-at-least-p 3 4 0)
      (case choice
        (:x11 (init-hint init-platform platform-x11))
        (:wayland (init-hint init-platform platform-wayland))
        (:null (init-hint init-platform platform-null))
        (otherwise nil)))
    ;; The Wayland libdecor hint was added in 3.3.9.  Disable it by default
    ;; for Wayland sessions; this avoids loading libdecor-gtk into SBCL and
    ;; other host runtimes unless the user explicitly opts in.
    (when (and (%version-at-least-p 3 3 9)
               (%wayland-session-p choice))
      (let ((mode (%string-choice (uiop:getenv "LWLGL_GLFW_LIBDECOR"))))
        (init-hint wayland-libdecor
                   (if (or (string= (or mode "") "prefer")
                           (string= (or mode "") "on")
                           (not *disable-wayland-libdecor*))
                       wayland-prefer-libdecor
                       wayland-disable-libdecor))))
    choice))

(defun last-error ()
  "Returns GLFW's last error code and description as two values, clearing it."
  (%ensure-glfw)
  (cffi:with-foreign-object (description :pointer)
    (setf (cffi:mem-ref description :pointer) (cffi:null-pointer))
    (let* ((code (%glfw-get-error description))
           (pointer (cffi:mem-ref description :pointer)))
      (values code
              (unless (cffi:null-pointer-p pointer)
                (cffi:foreign-string-to-lisp pointer))))))

(defun glfw-diagnostics ()
  "Returns a plist useful when reporting GLFW startup failures."
  (multiple-value-bind (major minor revision) (get-version)
    (list :version (list major minor revision)
          :version-string (version-string)
          :platform-preference (%platform-choice)
          :xdg-session-type (uiop:getenv "XDG_SESSION_TYPE")
          :display (uiop:getenv "DISPLAY")
          :wayland-display (uiop:getenv "WAYLAND_DISPLAY")
          :libdecor-policy (or (uiop:getenv "LWLGL_GLFW_LIBDECOR")
                               (if *disable-wayland-libdecor* "disable" "prefer")))))

(defun init ()
  (%ensure-glfw)
  (%configure-init-hints)
  (= (%glfw-init) true))
(defun terminate () (%glfw-terminate))
(defun version-string () (%ensure-glfw) (%glfw-get-version-string))
(defun default-window-hints () (%glfw-default-window-hints))
(defun window-hint (hint value) (%glfw-window-hint hint value))
(defun poll-events () (%glfw-poll-events))
(defun wait-events () (%glfw-wait-events))
(defun wait-events-timeout (timeout) (%glfw-wait-events-timeout (coerce timeout 'double-float)))
(defun post-empty-event () (%glfw-post-empty-event))
(defun get-time () (%glfw-get-time))
(defun set-time (time) (%glfw-set-time (coerce time 'double-float)))
(defun swap-interval (interval) (%glfw-swap-interval interval))
(defun get-proc-address (name) (%glfw-get-proc-address name))
(defun vulkan-supported-p ()
  (%ensure-glfw)
  (not (zerop (%glfw-vulkan-supported))))

(defun required-vulkan-instance-extensions ()
  "Returns GLFW's required Vulkan instance extension names, or NIL when Vulkan is unavailable."
  (%ensure-glfw)
  (cffi:with-foreign-object (count :unsigned-int)
    (let ((pointer (%glfw-get-required-instance-extensions count)))
      (if (cffi:null-pointer-p pointer)
          nil
          (loop for i below (cffi:mem-ref count :unsigned-int)
                for item = (cffi:mem-aref pointer :pointer i)
                collect (cffi:foreign-string-to-lisp item))))))
