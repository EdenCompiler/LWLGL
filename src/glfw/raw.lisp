(in-package #:lwlgl.glfw)

(register-native-module
 :glfw
 (platform-library-names
  :windows '("glfw3.dll" "glfw.dll")
  :macos '("libglfw.3.dylib" "libglfw.dylib")
  :linux '("libglfw.so.3" "libglfw.so")))

(defconstant true 1)
(defconstant false 0)
(defconstant press 1)
(defconstant release 0)
(defconstant repeat 2)

;; GLFW initialization hints / runtime platforms.
;; GLFW_PLATFORM was added in 3.4; GLFW_WAYLAND_LIBDECOR in 3.3.9.
(defconstant init-platform #x00050003)
(defconstant wayland-libdecor #x00053001)
(defconstant any-platform #x00060000)
(defconstant platform-win32 #x00060001)
(defconstant platform-cocoa #x00060002)
(defconstant platform-wayland #x00060003)
(defconstant platform-x11 #x00060004)
(defconstant platform-null #x00060005)
(defconstant wayland-prefer-libdecor #x00038001)
(defconstant wayland-disable-libdecor #x00038002)

(defparameter *glfw-platform-preference* :auto
  "Runtime GLFW platform preference: :AUTO, :X11, :WAYLAND or :NULL.
The environment variable LWLGL_GLFW_PLATFORM overrides this value.")
(defparameter *disable-wayland-libdecor* t
  "When true, disable GLFW's optional libdecor plugin on Wayland by default.
Set LWLGL_GLFW_LIBDECOR=prefer to opt back in.")

