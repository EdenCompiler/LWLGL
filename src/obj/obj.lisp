(in-package #:lwlgl.obj)

(defconstant +obj-vertex-stride-floats+ 8)

(define-condition obj-error (error)
  ((line :initarg :line :reader obj-error-line)
   (message :initarg :message :reader obj-error-message))
  (:report (lambda (condition stream)
             (format stream "OBJ parse error~@[ at line ~D~]: ~A"
                     (obj-error-line condition) (obj-error-message condition)))))

(defstruct obj-mesh
  (vertices #() :type vector)
  (indices #() :type vector)
  (vertex-count 0 :type (integer 0 *))
  (triangle-count 0 :type (integer 0 *))
  (has-normals-p nil :type boolean)
  (has-texcoords-p nil :type boolean)
  bounds source)

(defun %split-whitespace (string)
  (let ((result '()) (start nil) (length (length string)))
    (labels ((emit (end)
               (when start (push (subseq string start end) result) (setf start nil))))
      (dotimes (i length)
        (if (find (char string i) (list #\Space #\Tab #\Return #\Newline))
            (emit i)
            (unless start (setf start i))))
      (emit length))
    (nreverse result)))

(defun %split-slash (string)
  (let ((parts '()) (start 0))
    (loop for i from 0 below (length string)
          when (char= (char string i) #\/)
            do (push (subseq string start i) parts) (setf start (1+ i)))
    (push (subseq string start) parts)
    (nreverse parts)))

(defun %parse-int (text line)
  (handler-case (parse-integer text)
    (error () (error 'obj-error :line line :message (format nil "Invalid integer ~S." text)))))

(defun %parse-float (text line)
  (handler-case
      (let ((*read-eval* nil))
        (multiple-value-bind (value position) (read-from-string text nil nil)
          (unless (and value (= position (length text)) (numberp value))
            (error "bad float"))
          (coerce value 'single-float)))
    (error () (error 'obj-error :line line :message (format nil "Invalid number ~S." text)))))

(defun %resolve-index (index count line kind)
  (let ((resolved (cond ((plusp index) (1- index))
                        ((minusp index) (+ count index))
                        (t -1))))
    (unless (<= 0 resolved (1- count))
      (error 'obj-error :line line :message (format nil "~A index ~D is out of range for ~D entries." kind index count)))
    resolved))

(defun %parse-face-ref (token positions texcoords normals line)
  (let* ((parts (%split-slash token))
         (vi (%resolve-index (%parse-int (first parts) line) (length positions) line "position"))
         (ti (and (second parts) (plusp (length (second parts)))
                  (%resolve-index (%parse-int (second parts) line) (length texcoords) line "texcoord")))
         (ni (and (third parts) (plusp (length (third parts)))
                  (%resolve-index (%parse-int (third parts) line) (length normals) line "normal"))))
    (list vi ti ni)))

(defun parse-obj (text &key source)
  "Parses Wavefront OBJ text into a single indexed mesh. Faces are fan-triangulated; negative indices are supported.
The vertex layout is position.xyz, normal.xyz, texcoord.uv (8 floats)."
  (let ((positions (make-array 0 :adjustable t :fill-pointer 0))
        (texcoords (make-array 0 :adjustable t :fill-pointer 0))
        (normals (make-array 0 :adjustable t :fill-pointer 0))
        (vertices (make-array 0 :element-type 'single-float :adjustable t :fill-pointer 0))
        (indices (make-array 0 :element-type '(unsigned-byte 32) :adjustable t :fill-pointer 0))
        (vertex-map (make-hash-table :test #'equal))
        (has-normals nil) (has-texcoords nil) (line-number 0))
    (labels ((emit-vertex (ref)
               (or (gethash ref vertex-map)
                   (destructuring-bind (vi ti ni) ref
                     (let* ((position (aref positions vi))
                            (texcoord (and ti (aref texcoords ti)))
                            (normal (and ni (aref normals ni)))
                            (index (hash-table-count vertex-map)))
                       (dolist (value (list (lwlgl.math:vec3-x position) (lwlgl.math:vec3-y position) (lwlgl.math:vec3-z position)
                                            (if normal (lwlgl.math:vec3-x normal) 0.0f0)
                                            (if normal (lwlgl.math:vec3-y normal) 0.0f0)
                                            (if normal (lwlgl.math:vec3-z normal) 0.0f0)
                                            (if texcoord (lwlgl.math:vec2-x texcoord) 0.0f0)
                                            (if texcoord (lwlgl.math:vec2-y texcoord) 0.0f0)))
                         (vector-push-extend (coerce value 'single-float) vertices))
                       (setf (gethash ref vertex-map) index)
                       index)))))
      (with-input-from-string (stream text)
        (loop for raw = (read-line stream nil nil) while raw do
          (incf line-number)
          (let* ((comment (position #\# raw))
                 (line (string-trim (list #\Space #\Tab #\Return #\Newline) (if comment (subseq raw 0 comment) raw))))
            (unless (zerop (length line))
              (let ((parts (%split-whitespace line)))
                (cond
                  ((string= (first parts) "v")
                   (unless (>= (length parts) 4) (error 'obj-error :line line-number :message "v requires x y z."))
                   (vector-push-extend (lwlgl.math:vec3 (%parse-float (second parts) line-number)
                                                        (%parse-float (third parts) line-number)
                                                        (%parse-float (fourth parts) line-number)) positions))
                  ((string= (first parts) "vt")
                   (unless (>= (length parts) 3) (error 'obj-error :line line-number :message "vt requires u v."))
                   (vector-push-extend (lwlgl.math:vec2 (%parse-float (second parts) line-number)
                                                        (%parse-float (third parts) line-number)) texcoords))
                  ((string= (first parts) "vn")
                   (unless (>= (length parts) 4) (error 'obj-error :line line-number :message "vn requires x y z."))
                   (vector-push-extend (lwlgl.math:vec3 (%parse-float (second parts) line-number)
                                                        (%parse-float (third parts) line-number)
                                                        (%parse-float (fourth parts) line-number)) normals))
                  ((string= (first parts) "f")
                   (let ((tokens (rest parts)))
                     (when (< (length tokens) 3) (error 'obj-error :line line-number :message "f requires at least three vertices."))
                     (let ((refs (mapcar (lambda (token) (%parse-face-ref token positions texcoords normals line-number)) tokens)))
                       (when (some #'second refs) (setf has-texcoords t))
                       (when (some #'third refs) (setf has-normals t))
                       (loop for i from 1 below (1- (length refs))
                             do (dolist (ref (list (first refs) (nth i refs) (nth (1+ i) refs)))
                                  (vector-push-extend (emit-vertex ref) indices))))))))))))
      (let* ((point-count (length positions))
             (bounds (when (plusp point-count)
                       (lwlgl.math:aabb-from-points (loop for point across positions collect point)))))
        (make-obj-mesh :vertices (coerce vertices '(simple-array single-float (*)))
                       :indices (coerce indices '(simple-array (unsigned-byte 32) (*)))
                       :vertex-count (hash-table-count vertex-map)
                       :triangle-count (truncate (length indices) 3)
                       :has-normals-p has-normals :has-texcoords-p has-texcoords
                       :bounds bounds :source source)))))

(defun load-obj (path)
  (parse-obj (uiop:read-file-string path) :source path))
